# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default for local dev — auto-created on first run):
DATABASE_URL=sqlite+aiosqlite:///./tls_analyzer.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── JWT ────────────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-64-char-hex-string
JWT_EXPIRE_MINUTES=1440          # 24 hours

# ── OAuth ──────────────────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-secret

# ── SMTP (forgot-password emails + contact form) ───────────────────────────────
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → generate App Password
# IMPORTANT: paste the 16-char App Password with NO spaces
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your16charapppassword
CONTACT_RECIPIENT=your.email@gmail.com

# ── Frontend URL (used in password-reset email links) ─────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Scan behaviour (optional) ─────────────────────────────────────────────────
SCAN_TIMEOUT=10
SCAN_CONCURRENCY=20

# ── ElasticSearch (optional — app works without it) ───────────────────────────
# ES_URL=http://localhost:9200
